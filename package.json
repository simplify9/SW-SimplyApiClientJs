{
  "name": "@simplify9/simplyapiclient",
  "version": "2.2.3",
  "description": "A powerful JavaScript API client built on axios with dependency injection, perfect for React and Node.js applications",
  "main": "dist/index.js",
  "typings": "dist/index",
  "scripts": {
    "test": "jest --config jestconfig.json",
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "tslint -p tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint",
    "preversion": "npm run lint",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "author": "Simplify9",
  "license": "MIT",
  "peerDependencies": {
    "axios": ">=0.21.1 <2.0.0"
  },
  "files": [
    "dist/*"
  ],
  "devDependencies": {
    "@types/jest": "^26.0.5",
    "axios": "^1.6.8",
    "jest": "^26.1.0",
    "prettier": "^3.9.5",
    "ts-jest": "^26.1.3",
    "tslint": "^6.1.2",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^4.9.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simplify9/SimplyApiClientJs"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/simplify9/"
  }
}
